# Local / VPS reverse proxy for AutoHood API
# Replace :80 with your domain (e.g. api.autohood.com) for automatic HTTPS

:80 {
	encode gzip zstd

	# Health endpoint
	handle /api/health {
		reverse_proxy api:3001
	}

	# API
	handle /api/* {
		reverse_proxy api:3001
	}

	# Fallback
	handle {
		respond "AutoHood API — use /api/*" 200
	}
}
