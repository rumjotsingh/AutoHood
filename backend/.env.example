# Server
PORT=3001
NODE_ENV=development
API_VERSION=v1

# Frontend
FRONTEND_URL=http://localhost:3000
FRONTEND_PROD_URL=https://auto-hood.vercel.app/
CLIENT_URL=https://carsystem-zeta.vercel.app

# MongoDB
MONGO_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/autohood?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-me
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRE=30d

# Redis — local/Docker (preferred when REDIS_HOST is set)
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# Upstash (only used when REDIS_HOST is unset)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Cloudinary
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=
CLOUDINARY_URL=

# Email
EMAIL_USER=
EMAIL_PASS=
EMAIL_RECEIVER=
EMAIL_FROM="AutoHood <noreply@autohood.com>"

# Payments
PAYMENT_DEMO_MODE=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
CURRENCY=INR
TAX_RATE=0.18

# Google OAuth
GOOGLE_CLIENT_ID=

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10000

# Uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,image/webp
